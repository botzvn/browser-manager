{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./packages/frontend/src/*"],
      "@botzvn/bridge": ["./packages/bridges/web/src/index.ts"],
      "@botzvn/frontend/*": ["./packages/frontend/src/*"]
    }
  }
}
