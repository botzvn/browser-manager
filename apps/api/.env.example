# BotZVN Browser Core — Environment Configuration
# Core version is designed to run locally with zero-config.
# Uncomment and modify the variables below ONLY if you need to override the defaults.

# ── Server ────────────────────────────────────────────────────────────────────
# PORT=8080
# MANAGER_PORT=8080

# ── Directories & Paths ───────────────────────────────────────────────────────
# Base directory for all data
# MANAGER_DATA_DIR=.botzvn-manager

# Specific sub-directories (defaults to subfolders inside data dir)
# RUNTIME_DIR=.botzvn-manager/runtime
# PROFILES_DIR=.botzvn-manager/profiles
# LOGS_DIR=.botzvn-manager/logs

# Path to the compiled Chromium browser binary
# BROWSER_PATH=bin/botzvn

# Default Chromium config file to load
# CONFIG_FILE=

# ── Database ──────────────────────────────────────────────────────────────────
# By default, Core uses SQLite
# SQLITE_FILE=.botzvn-manager/botzvn-manager.db
# DATABASE_SETUP_FILE=.botzvn-manager/database-setup.json

# Uncomment below to force PostgreSQL
# DATABASE_CLIENT=pg
# DATABASE_URL=postgresql://user:pass@localhost:5432/botzvn

# ── Display & Screen Resolution ───────────────────────────────────────────────
# SCREEN_WIDTH=1365
# SCREEN_HEIGHT=768

# ── Port Allocations (For isolated browser instances) ─────────────────────────
# X11 Display numbers
# DISPLAY_BASE=100
# DISPLAY_MAX=299

# Chrome DevTools Protocol (CDP) ports
# CDP_PORT_BASE=9300
# CDP_PORT_MAX=9499

# VNC ports
# VNC_PORT_BASE=5900
# VNC_PORT_MAX=6099

# ── Other Settings ────────────────────────────────────────────────────────────
# Idle timeout before suspending unused views
# VIEW_IDLE_MS=30000

# Browser launch CDP connection timeout
# BROWSER_CDP_TIMEOUT_MS=45000


# Botzvn browser API Token
# BOTZVN_TOKEN=w930Xitejc69TM4hEPOa2V0j9U5/prZ30s5NWnf-5VJm8PjoYo/ehusKvSHRc9ol3zJfLVBVpP3OIjOCwrza

